RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=mario@buyorbesold.com
RESEND_AUDIENCE_ID=
NEXT_PUBLIC_SITE_URL=https://buyorbesold.com

# Scanner (free tier: 60 calls/min)
# Sign up at https://finnhub.io/dashboard and paste the key below.
# Without this the scanner runs in degraded mode (no float filter).
FINNHUB_API_KEY=

# Claude API (Anthropic) — drafts earnings reactions, event briefs, and
# per-user trade-history insights. System prompt is cached, so typical
# cost is ~$0.05 per draft.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Trading journal auth (magic link via Resend)
# ADMIN_EMAIL: the email whose session can write to the public journal.
#              Any verified email can sign in and get a private journal.
# AUTH_SECRET: a random 32+ char string used to sign session JWTs.
#              Generate with: openssl rand -base64 32
ADMIN_EMAIL=mario@buyorbesold.com
AUTH_SECRET=

# Google sign-in (optional — if unset, only magic-link email auth is shown)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Type: Web application. Authorized redirect URIs:
#   https://buyorbesold.com/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel KV (auto-injected when you link a KV store in the Vercel dashboard)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Broker verification (Alpaca OAuth)
# Register an OAuth app at https://app.alpaca.markets/brokerage/apps
ALPACA_CLIENT_ID=
ALPACA_CLIENT_SECRET=
ALPACA_REDIRECT_URI=https://buyorbesold.com/api/social/verify/callback

# AI brief generation (Claude API — used by the 3 daily crons)
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Cron (Vercel auto-signs requests, but we validate this header as a second layer)
# Generate with: openssl rand -base64 32
CRON_SECRET=
