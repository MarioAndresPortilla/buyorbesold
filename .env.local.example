RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=mario@buyorbesold.com
RESEND_AUDIENCE_ID=
NEXT_PUBLIC_SITE_URL=https://buyorbesold.com

# Scanner (free tier: 60 calls/min)
# Sign up at https://finnhub.io/dashboard and paste the key below.
# Without this the scanner runs in degraded mode (no float filter).
FINNHUB_API_KEY=

# Trading journal auth (magic link via Resend)
# ADMIN_EMAIL: the only email allowed to request magic links / write trades.
# AUTH_SECRET: a random 32+ char string used to sign session JWTs.
#              Generate with: openssl rand -base64 32
ADMIN_EMAIL=mario@buyorbesold.com
AUTH_SECRET=

# Vercel KV (auto-injected when you link a KV store in the Vercel dashboard)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
